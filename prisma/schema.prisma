generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(EDITOR)
  createdAt    DateTime @default(now())
  isActive     Boolean  @default(true)
  avatar       String?
  bio          String?  @db.Text
  designation  String?
  socialLinks  Json?
  posts        Post[]   @relation("PostAuthor")
}

model Page {
  id          Int       @id @default(autoincrement())
  slug        String    @unique
  title       String
  metaDesc    String?   @db.Text
  isPublished Boolean   @default(true)
  sections    Section[]
}

model Section {
  id       Int     @id @default(autoincrement())
  pageId   Int
  type     String
  order    Int     @default(0)
  isActive Boolean @default(true)
  data     Json
  page     Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId], map: "Section_pageId_fkey")
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  status    String   @default("NEW")
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id              Int       @id @default(autoincrement())
  slug            String    @unique
  title           String
  excerpt         String?   @db.Text
  content         String    @db.LongText
  featuredImg     String?
  isPublished     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  authorId        Int
  categoryId      Int?
  h1              String?
  metaDesc        String?   @db.Text
  metaTitle       String?
  showToc         Boolean   @default(true)
  featuredImgAlt  String?
  publishedAt     DateTime  @default(now())
  readTimeMinutes Int?
  author          AdminUser @relation("PostAuthor", fields: [authorId], references: [id])
  category        Category? @relation(fields: [categoryId], references: [id])
  tags            Tag[]     @relation("PostTags")

  @@index([authorId], map: "Post_authorId_fkey")
  @@index([categoryId], map: "Post_categoryId_fkey")
}

model Category {
  id    Int    @id @default(autoincrement())
  slug  String @unique
  name  String
  posts Post[]
}

model Tag {
  id    Int    @id @default(autoincrement())
  slug  String @unique
  name  String
  posts Post[] @relation("PostTags")
}

model Media {
  id         Int      @id @default(autoincrement())
  filename   String
  url        String   @unique
  mimeType   String
  sizeBytes  Int
  createdAt  DateTime @default(now())
  base64Data String?  @db.LongText
}

model SiteSettings {
  id                 Int      @id @default(autoincrement())
  siteName           String   @default("Virginia Business Solutions")
  logoUrl            String?
  contactEmail       String?
  contactPhone       String?
  footerText         String?  @db.Text
  seoDefaultTitle    String   @default("VBS - Digital Career Guidance")
  seoDefaultDesc     String?  @db.Text
  navLinks           Json?
  updatedAt          DateTime @updatedAt
  blogBannerSubtitle String?  @db.Text
  blogBannerTitle    String?  @default("Build Louder.")
  blogMetaDesc       String?  @db.Text
  blogMetaTitle      String?  @default("VBS Engineering Blog")
  socialLinks        Json?
}

model AffiliateLink {
  id          Int      @id @default(autoincrement())
  title       String
  url         String   @db.Text
  platform    String   @default("Other")
  category    String   @default("Course")
  description String?  @db.Text
  commission  String?
  clicks      Int      @default(0)
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  SUPER_ADMIN
  EDITOR
  VIEWER
}
